/**
 * ePepper firmware configuration.
 *
 * Edit these values before flashing, or they will be overwritten
 * by WiFi provisioning on first boot.
 */

#ifndef EPEPPER_CONFIG_H
#define EPEPPER_CONFIG_H

// ----- WiFi -----
#define WIFI_SSID         "YOUR_WIFI_SSID"
#define WIFI_PASSWORD     "YOUR_WIFI_PASSWORD"
#define WIFI_TIMEOUT_MS   15000

// ----- Server -----
#define SERVER_URL        "https://epepper.fyx.ch"
#define API_KEY           "CHANGE_ME"  // generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

// ----- Display -----
// reTerminal E1001: 7.5" mono, UC8179, 800x480
#define DISPLAY_WIDTH     800
#define DISPLAY_HEIGHT    480

// Clock/date overlay (drawn over the server-rendered footer strip, bottom-left)
#define CLOCK_X        16   // x where text starts; mirrors server MARGIN
#define CLOCK_Y        456  // top of 16-px text; bottom (y=472) matches page indicator bottom
#define CLOCK_RECT_X   8
#define CLOCK_RECT_Y   452
#define CLOCK_RECT_W   480  // wide enough for "HH:MM <localized date> X.YZV"
#define CLOCK_RECT_H   28

// Top-edge glyphs marking physical button positions on the reTerminal.
// Drawn over the recipe image on every full refresh; not partial-refreshed.
// Tune the centers if they don't line up with the physical buttons.
#define BTN_GLYPH_Y          2     // px from top edge
// Centers tuned against the reTerminal E1001 physical button strip — the
// three buttons cluster right-of-center, not evenly across the panel.
#define BTN_GLYPH_PREV_X     440   // center x for left button (Prev / KEY2)
#define BTN_GLYPH_NEXT_X     460   // center x for middle button (Next / KEY1)
#define BTN_GLYPH_REFRESH_X  540   // center x for right button (Refresh / KEY0)

// ----- Timing -----
#define CLOCK_INTERVAL_S        60     // update clock every 1 minute
#define NTP_SYNC_INTERVAL_S     3600   // sync NTP every hour
#define WARM_WINDOW_MS          15000  // stay awake after a button press to skip cold-start next time
#define FULL_REFRESH_INTERVAL_S 1800   // force full panel refresh every 30 min so partial-refresh artifacts don't accumulate

// ----- Pins (reTerminal E1001) -----
#define EPD_CLK   7
#define EPD_MOSI  9
#define EPD_CS    10
#define EPD_DC    11
#define EPD_RST   12
#define EPD_BUSY  13

// Status LED (active LOW)
#define LED_PIN   6

// Buttons (active LOW, hardware pull-ups)
#define BTN_REFRESH  3   // KEY0 — right (green), refresh display
#define BTN_NEXT     4   // KEY1 — middle, next page
#define BTN_PREV     5   // KEY2 — left, previous page
#define BTN_DEBOUNCE_MS 50

// I2C for SHT4x temp/humidity sensor
#define I2C_SDA   19
#define I2C_SCL   20
#define SHT4X_ADDR     0x44   // SHT40-AD1B default 7-bit address
#define SHT4X_CMD_MEAS 0xFD   // measure T+RH, high precision (~8.2 ms)

// Buzzer (piezo)
#define BUZZER_PIN 45

// Battery ADC
#define BATTERY_ADC_PIN    1
#define BATTERY_ENABLE_PIN 21

#endif // EPEPPER_CONFIG_H
