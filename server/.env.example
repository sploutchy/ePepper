TELEGRAM_BOT_TOKEN=your_token_here
ALLOWED_USERS=
API_PORT=8080
# Required. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Server refuses to start if this is unset or empty.
API_KEY=

# Optional: send a gzipped DB snapshot to this chat at the daily
# midnight tick — but only when the library has changed since the
# previous upload. Telegram channel id (e.g. -1003608522302) with the
# bot added as admin.
# BACKUP_CHAT_ID=

# Optional: public URL of the web app, e.g. https://epepper.example.com.
# When set, the bot's /start and /help link to <WEB_URL>/app/ as a
# clickable shortcut.
# WEB_URL=

# Optional: local wall-clock hour (0-23, default 6) the e-ink panel
# aligns its daily timer wake to. The server returns the matching
# seconds-until-next-hit on /version; the firmware uses it instead
# of a flat 24 h offset.
# DEVICE_WAKE_HOUR_LOCAL=6

# Optional: bind address for the FastAPI server inside the container.
# API_HOST=0.0.0.0

# Optional: in-container path for the SQLite repertoire + backup-state
# file. Override only if you've remapped the bind-mount target.
# DATA_DIR=/app/data

# Optional: max megabytes accepted by the web photo upload endpoint. Default: 8.
# PHOTO_MAX_MB=8

# Optional: OpenAI-compatible LLM endpoint (Infomaniak AI Tools).
# When both URL + KEY are set, the URL flow falls back to the LLM when
# recipe-scrapers fails (and no embedded JSON-LD is present), and
# photo uploads are OCR'd into recipes. When unset, those paths
# degrade — URL fallback skipped, photo uploads rejected.
#
# LLM_API_URL is the OpenAI base (the client appends /chat/completions):
#   https://api.infomaniak.com/2/ai/<product_id>/openai/v1
# LLM_API_KEY=
# LLM_API_URL=
# LLM_TEXT_MODEL=mistralai/Ministral-3-14B-Instruct-2512
# LLM_VISION_MODEL=mistralai/Ministral-3-14B-Instruct-2512
# Translation (recipe → bilingual FTS keywords) defaults to the same
# model as the URL/OCR path. Falls back to LLM_TEXT_MODEL if cleared.
# LLM_TRANSLATE_MODEL=mistralai/Ministral-3-14B-Instruct-2512
